# Database Configuration
DATABASE_URL="file:./db/custom.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/ai_healthcare"

# Bahmni Configuration
BAHMNI_URL="https://your-bahmni-instance.org"
BAHMNI_USERNAME="your-username"
BAHMNI_PASSWORD="your-password"
BAHMNI_FHIR_ENDPOINT="/openmrs/ws/fhir2/R4"

# AI Configuration
AI_MODEL="medgemma"
AI_TEMPERATURE="0.7"
AI_MAX_TOKENS="2048"

# Feature Flags
ENABLE_CLINICAL_DECISION_SUPPORT="true"
ENABLE_DRUG_INTERACTION_CHECK="true"
ENABLE_IMAGE_ANALYSIS="true"
ENABLE_VOICE_TRANSCRIPTION="true"

# Safety Settings
REQUIRE_HUMAN_REVIEW="true"
LOG_ALL_INTERACTIONS="true"
SAFETY_ALERT_THRESHOLD="0.8"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-key-here"

# OAuth Providers (optional)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# API Key for service-to-service authentication
GELANI_API_KEY="your-api-key-here"

# Backup Configuration
BACKUP_DIR="./db/backups"
BACKUP_ON_WRITE="true"
