generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Patient records - Smart Patient Identity System
model Patient {
  id                        String              @id @default(cuid())
  bahmniPatientId           String?             @unique
  mrn                       String?             @unique
  nationalHealthId          String?             @unique
  nationalIdType            String?
  biometricId               String?
  facialRecognitionId       String?
  patientDigitalId          String?             @unique
  smartCardSerialNumber     String?
  title                     String?
  firstName                 String
  lastName                  String
  middleName                String?
  preferredName             String?
  dateOfBirth               DateTime
  gender                    String
  bloodType                 String?
  rhFactor                  String?
  maritalStatus             String?
  ethnicity                 String?
  race                      String?
  nationalities             String?
  languages                 String?
  phone                     String?
  phoneType                 String?
  alternatePhone            String?
  email                     String?
  address                   String?
  city                      String?
  state                     String?
  postalCode                String?
  country                   String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  emergencyContactRelation  String?
  emergencyContactEmail     String?
  emergencyContact2Name     String?
  emergencyContact2Phone    String?
  emergencyContact2Relation String?
  emergencyContact2Email    String?
  emergencyContacts         String?
  allergies                 String?
  allergyCritical           Boolean             @default(false)
  bloodTypeEmergency        String?
  organDonorStatus          String?
  pregnancyStatus           String?
  estimatedDueDate          DateTime?
  chronicConditions         String?
  implantedDevices          String?
  fallRisk                  Boolean             @default(false)
  fallRiskLevel             String?
  infectiousDiseaseStatus   String?
  infectionIsolationType    String?
  dnrOrder                  Boolean             @default(false)
  dnrOrderDate              DateTime?
  dnrOrderPhysician         String?
  isolationPrecautions      String?
  highRiskMedications       String?
  suicideRisk               Boolean             @default(false)
  elopementRisk             Boolean             @default(false)
  languagePrimary           String?
  languageSecondary         String?
  interpreterNeeded         Boolean             @default(false)
  religion                  String?
  religiousConsiderations   String?
  disabilityStatus          String?
  mobilityStatus            String?
  mobilityAid               String?
  caregiverName             String?
  caregiverPhone            String?
  caregiverRelation         String?
  advanceDirective          Boolean             @default(false)
  advanceDirectiveLocation  String?
  healthcareProxyName       String?
  healthcareProxyPhone      String?
  lastHospitalVisit         DateTime?
  lastPhysicianName         String?
  lastPhysicianSpecialty    String?
  primaryCarePhysician      String?
  primaryCareFacility       String?
  triagePriority            String?
  totalAdmissions           Int                 @default(0)
  totalEdVisits             Int                 @default(0)
  insurancePrimary          String?
  insurancePrimaryId        String?
  insurancePrimaryGroup     String?
  insuranceSecondary        String?
  insuranceSecondaryId      String?
  insuranceVerified         Boolean             @default(false)
  insuranceVerifiedDate     DateTime?
  aiRiskScore               Float?
  aiRiskLevel               String?
  aiRiskFactors             String?
  aiReadmissionRisk         Float?
  aiMortalityRisk           Float?
  aiTriagePrediction        String?
  aiEmergencyAlerts         String?
  aiLastAssessment          DateTime?
  aiPopulationHealthTag     String?
  qrCodeData                String?
  qrCodeGenerated           DateTime?
  nfcEnabled                Boolean             @default(false)
  rfidTagId                 String?
  digitalAccessEnabled      Boolean             @default(false)
  patientPortalAccess       Boolean             @default(false)
  patientPortalLastAccess   DateTime?
  fingerprintRegistered     Boolean             @default(false)
  fingerprintTemplateId     String?
  irisScanRegistered        Boolean             @default(false)
  irisScanTemplateId        String?
  voicePrintRegistered      Boolean             @default(false)
  voicePrintTemplateId      String?
  isActive                  Boolean             @default(true)
  lastSyncFromBahmni        DateTime?
  patientPhoto              String?
  cardPrintDate             DateTime?
  cardExpiryDate            DateTime?
  notes                     String?
  attachments               String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  aiInteractions            AIInteraction[]
  consultations             Consultation[]
  diagnoses                 Diagnosis[]
  labOrders                 LabOrder[]
  labResults                LabResult[]
  documents                 MedicalDocument[]
  medications               PatientMedication[]
  smartCardAccess           SmartCardAccess[]
  voiceNotes                VoiceNote[]
  clinicalOrders            ClinicalOrder[]
  nurseTasks                NurseTask[]
  prescriptions             Prescription[]
  soapNotes                 SoapNote[]
  vitals                    VitalSigns[]
}

/// Clinical consultations/encounters
model Consultation {
  id                     String              @id @default(cuid())
  patientId              String
  consultationDate       DateTime            @default(now())
  consultationType       String
  chiefComplaint         String?
  subjectiveNotes        String?
  objectiveNotes         String?
  assessment             String?
  plan                   String?
  aiSummaryGenerated     Boolean             @default(false)
  aiDiagnosisSuggestions String?
  providerName           String?
  department             String?
  status                 String              @default("in-progress")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  aiInteractions         AIInteraction[]
  patient                Patient             @relation(fields: [patientId], references: [id])
  diagnoses              Diagnosis[]
  documents              MedicalDocument[]
  medications            PatientMedication[]
  voiceNotes             VoiceNote[]
}

/// Patient diagnoses
model Diagnosis {
  id             String        @id @default(cuid())
  patientId      String
  consultationId String?
  icdCode        String?
  snomedCode     String?
  diagnosisName  String
  description    String?
  diagnosisType  String        @default("primary")
  severity       String?
  status         String        @default("active")
  diagnosedDate  DateTime      @default(now())
  resolvedDate   DateTime?
  aiSuggested    Boolean       @default(false)
  aiConfidence   Float?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id])
}

/// Patient medications
model PatientMedication {
  id                String        @id @default(cuid())
  patientId         String
  consultationId    String?
  medicationName    String
  genericName       String?
  dosage            String?
  frequency         String?
  route             String?
  duration          String?
  prescribedBy      String?
  prescribedDate    DateTime      @default(now())
  status            String        @default("active")
  startDate         DateTime      @default(now())
  endDate           DateTime?
  interactionAlerts String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  consultation      Consultation? @relation(fields: [consultationId], references: [id])
  patient           Patient       @relation(fields: [patientId], references: [id])
}

/// Vital signs records - Enhanced with nurse attribution
model VitalSigns {
  id                     String     @id @default(cuid())
  patientId              String
  encounterId            String?
  temperature            Float?
  temperatureUnit        String     @default("C")
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  heartRate              Int?
  respiratoryRate        Int?
  oxygenSaturation       Float?
  weight                 Float?
  weightUnit             String     @default("kg")
  height                 Float?
  heightUnit             String     @default("cm")
  bmi                    Float?
  bloodGlucose           Float?
  glucoseUnit            String     @default("mmol/L")
  glucoseType            String?
  painScore              Int?
  consciousnessLevel     String?
  bpStatus               String?
  hrStatus               String?
  rrStatus               String?
  spo2Status             String?
  tempStatus             String?
  glucoseStatus          String?
  recordedBy             String
  recordedByName         String?
  recordedByRole         String?
  recordedAt             DateTime   @default(now())
  isAmendment            Boolean    @default(false)
  amendmentReason        String?
  originalVitalsId       String?
  notes                  String?
  soapNotes              SoapNote[]
  recorder               Employee   @relation(fields: [recordedBy], references: [employeeId])
  patient                Patient    @relation(fields: [patientId], references: [id])

  @@map("vital_signs")
}

/// Lab Orders - Doctor orders lab tests
model LabOrder {
  id              String         @id @default(cuid())
  patientId       String
  consultationId  String?
  orderNumber     String         @unique
  orderDate       DateTime       @default(now())
  priority        String         @default("routine")
  status          String         @default("pending")
  clinicalNotes   String?
  diagnosis       String?
  orderedBy       String?
  department      String?
  sampleCollected Boolean        @default(false)
  collectedAt     DateTime?
  collectedBy     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  patient         Patient        @relation(fields: [patientId], references: [id])
  orderItems      LabOrderItem[]
  labResults      LabResult[]
}

/// Lab Order Items - Individual tests in an order
model LabOrderItem {
  id              String    @id @default(cuid())
  orderId         String
  testName        String
  testCode        String?
  category        String?
  subcategory     String?
  unit            String?
  referenceRange  String?
  status          String    @default("pending")
  resultValue     String?
  interpretation  String?
  resultNotes     String?
  resultEnteredAt DateTime?
  enteredBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  order           LabOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

/// Lab Results - Completed results (historical record)
model LabResult {
  id               String    @id @default(cuid())
  patientId        String
  orderId          String?
  testName         String
  testCode         String?
  category         String?
  resultValue      String
  unit             String?
  referenceRange   String?
  interpretation   String?
  orderedDate      DateTime  @default(now())
  resultDate       DateTime?
  aiInterpretation String?
  aiAlertFlag      Boolean   @default(false)
  enteredBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  order            LabOrder? @relation(fields: [orderId], references: [id])
  patient          Patient   @relation(fields: [patientId], references: [id])
}

model MedicalDocument {
  id             String        @id @default(cuid())
  patientId      String
  consultationId String?
  documentType   String
  title          String
  content        String
  aiGenerated    Boolean       @default(false)
  aiModelUsed    String?
  fileUrl        String?
  fileType       String?
  authoredBy     String?
  authoredAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id])
}

model AIInteraction {
  id              String        @id @default(cuid())
  patientId       String?
  consultationId  String?
  interactionType String
  prompt          String
  response        String
  modelUsed       String?
  tokensUsed      Int?
  processingTime  Int?
  humanReviewed   Boolean       @default(false)
  reviewerNotes   String?
  safetyFlags     String?
  createdAt       DateTime      @default(now())
  consultation    Consultation? @relation(fields: [consultationId], references: [id])
  patient         Patient?      @relation(fields: [patientId], references: [id])
}

model VoiceNote {
  id             String        @id @default(cuid())
  patientId      String?
  consultationId String?
  audioDuration  Int?
  audioFormat    String?
  transcription  String
  status         String        @default("draft")
  tags           String?
  noteType       String        @default("general")
  targetField    String?
  recordedBy     String?
  recordedAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  patient        Patient?      @relation(fields: [patientId], references: [id])
}

model Drug {
  id                String   @id @default(cuid())
  name              String
  genericName       String?
  brandNames        String?
  drugClass         String?
  therapeuticClass  String?
  atcCode           String?
  standardDosage    String?
  dosageForms       String?
  contraindications String?
  sideEffects       String?
  pregnancyCategory String?
  drugInteractions  String?
  isActive          Boolean  @default(true)
  lastUpdated       DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model BahmniIntegration {
  id               String    @id @default(cuid())
  bahmniUrl        String
  apiEndpoint      String
  authType         String    @default("basic")
  username         String?
  password         String?
  apiKey           String?
  accessToken      String?
  syncEnabled      Boolean   @default(true)
  lastSyncAt       DateTime?
  syncInterval     Int       @default(60)
  connectionStatus String    @default("disconnected")
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model OdooIntegration {
  id               String    @id @default(cuid())
  odooUrl          String
  database         String?
  authType         String    @default("api-key")
  apiKey           String?
  username         String?
  password         String?
  syncEnabled      Boolean   @default(false)
  lastSyncAt       DateTime?
  syncInterval     Int       @default(30)
  syncPayments     Boolean   @default(true)
  syncInvoices     Boolean   @default(true)
  syncCRM          Boolean   @default(true)
  syncAccounting   Boolean   @default(true)
  syncSales        Boolean   @default(true)
  connectionStatus String    @default("disconnected")
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SystemSettings {
  id                            String   @id @default(cuid())
  aiModel                       String   @default("medgemma")
  aiTemperature                 Float    @default(0.7)
  aiMaxTokens                   Int      @default(2048)
  enableClinicalDecisionSupport Boolean  @default(true)
  enableDrugInteractionCheck    Boolean  @default(true)
  enableImageAnalysis           Boolean  @default(true)
  enableVoiceTranscription      Boolean  @default(true)
  requireHumanReview            Boolean  @default(true)
  logAllInteractions            Boolean  @default(true)
  safetyAlertThreshold          Float    @default(0.8)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model IntegrationSyncLog {
  id              String    @id @default(cuid())
  integrationType String
  module          String
  syncDirection   String    @default("inbound")
  recordsSynced   Int       @default(0)
  recordsFailed   Int       @default(0)
  status          String    @default("pending")
  errorMessage    String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  duration        Int?
  createdAt       DateTime  @default(now())
}

/// RL Arm - represents a suggestion type that can be learned
model RLArm {
  id              String       @id @default(cuid())
  armKey          String       @unique
  armType         String
  category        String
  qValue          Float        @default(0.5)
  alpha           Float        @default(1.0)
  beta            Float        @default(1.0)
  totalPulls      Int          @default(0)
  totalRewards    Float        @default(0)
  averageReward   Float        @default(0)
  acceptCount     Int          @default(0)
  rejectCount     Int          @default(0)
  acceptanceRate  Float        @default(0)
  totalRatings    Int          @default(0)
  ratingSum       Float        @default(0)
  avgRating       Float        @default(0)
  isActive        Boolean      @default(true)
  lastUpdated     DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  feedbackHistory RLFeedback[]
}

/// RL Feedback - individual feedback records
model RLFeedback {
  id             String   @id @default(cuid())
  armId          String
  feedbackType   String
  rating         Float?
  reward         Float
  context        String?
  suggestionType String?
  suggestionText String?
  sessionId      String?
  userId         String?
  createdAt      DateTime @default(now())
  arm            RLArm    @relation(fields: [armId], references: [id])
}

/// Healthcare Knowledge Base for RAG
model HealthcareKnowledge {
  id              String              @id @default(cuid())
  title           String
  content         String
  summary         String?
  category        String
  subcategory     String?
  specialty       String?
  keywords        String?
  icdCodes        String?
  snomedCodes     String?
  drugNames       String?
  embedding       String?
  embeddingHash   String?
  embeddingModel  String?             @default("semantic-v1")
  source          String?
  sourceUrl       String?
  sourceDate      DateTime?
  evidenceLevel   String?
  language        String              @default("en")
  version         String?
  lastReviewed    DateTime?
  isActive        Boolean             @default(true)
  retrievalCount  Int                 @default(0)
  usefulnessScore Float               @default(0.5)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  feedback        KnowledgeFeedback[]

  @@index([category])
  @@index([specialty])
  @@index([isActive])
}

/// RAG Query Log - tracks queries for optimization
model RAGQuery {
  id             String   @id @default(cuid())
  queryText      String
  queryType      String
  knowledgeIds   String?
  retrievalCount Int      @default(0)
  aiResponse     String?
  responseTime   Int?
  wasHelpful     Boolean?
  userRating     Int?
  patientId      String?
  consultationId String?
  userId         String?
  createdAt      DateTime @default(now())
}

/// Drug Interaction Knowledge (specialized for drug checking)
model DrugInteractionKnowledge {
  id              String   @id @default(cuid())
  drug1Name       String
  drug1Generic    String?
  drug2Name       String
  drug2Generic    String?
  severity        String
  mechanism       String?
  description     String
  clinicalEffects String?
  management      String?
  embedding       String?
  embeddingHash   String?
  evidenceLevel   String?
  literatureRef   String?
  onset           String?
  duration        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([drug1Name])
  @@index([drug2Name])
  @@index([severity])
}

/// Clinical Guideline Knowledge
model ClinicalGuidelineKnowledge {
  id                 String    @id @default(cuid())
  title              String
  guidelineId        String?
  organization       String?
  condition          String
  icdCode            String?
  summary            String
  fullContent        String
  specialty          String?
  patientGroup       String?
  recommendations    String?
  diagnosticCriteria String?
  treatmentOptions   String?
  evidenceLevel      String?
  lastUpdated        DateTime?
  validUntil         DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

/// Symptom Condition Mapping (for differential diagnosis)
model SymptomConditionMapping {
  id                      String   @id @default(cuid())
  symptomName             String
  symptomCategory         String?
  conditions              String
  ageGroup                String?
  genderSpecific          String?
  riskFactors             String?
  sensitivity             Float?
  specificity             Float?
  positiveLikelihoodRatio Float?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

/// LLM Integration - Single Source of Truth for AI providers
model LLMIntegration {
  id               String    @id @default(cuid())
  provider         String
  displayName      String
  baseUrl          String?
  username         String?
  password         String?
  apiKey           String?
  model            String
  isActive         Boolean   @default(true)
  isDefault        Boolean   @default(false)
  priority         Int       @default(0)
  settings         String?
  notes            String?
  totalRequests    Int       @default(0)
  lastUsed         DateTime?
  lastError        String?
  connectionStatus String    @default("untested")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([provider])
  @@index([isActive, isDefault])
}

/// RAG Service Configuration - Single Source of Truth for RAG services
model RAGServiceConfig {
  id                 String    @id @default(cuid())
  serviceName        String    @unique
  displayName        String
  description        String?
  serviceUrl         String
  port               Int
  healthEndpoint     String    @default("/health")
  serviceType        String    @default("rag")
  capabilities       String?
  isActive           Boolean   @default(true)
  isDefault          Boolean   @default(false)
  priority           Int       @default(0)
  settings           String?
  connectionStatus   String    @default("untested")
  lastHealthCheck    DateTime?
  lastError          String?
  responseTimeMs     Int?
  totalRequests      Int       @default(0)
  successfulRequests Int       @default(0)
  failedRequests     Int       @default(0)
  averageLatency     Float?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([serviceName])
  @@index([isActive, isDefault])
  @@index([serviceType])
}

/// Knowledge Feedback - User feedback on knowledge entries
model KnowledgeFeedback {
  id           String              @id @default(cuid())
  knowledgeId  String
  feedbackType String
  rating       Int?
  comment      String?
  queryText    String?
  userId       String?
  sessionId    String?
  createdAt    DateTime            @default(now())
  knowledge    HealthcareKnowledge @relation(fields: [knowledgeId], references: [id])

  @@index([knowledgeId])
  @@index([feedbackType])
}

/// Embedding Cache - Stores precomputed embeddings for faster search
model EmbeddingCache {
  id             String   @id @default(cuid())
  contentHash    String   @unique
  contentType    String
  contentId      String
  embedding      String
  embeddingModel String   @default("semantic-v1")
  contentLength  Int
  lastAccessed   DateTime @default(now())
  accessCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([contentHash])
  @@index([contentType])
}

/// Smart Card Access Log - Track when and where patient card is scanned
model SmartCardAccess {
  id              String   @id @default(cuid())
  patientId       String
  accessType      String
  accessLocation  String?
  accessPoint     String?
  scannedBy       String?
  scannerDeviceId String?
  scanMethod      String
  accessedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  patient         Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([accessType])
  @@index([accessedAt])
}

/// Employee/Staff Model for IAM
model Employee {
  id                 String          @id @default(uuid())
  employeeId         String          @unique
  firstName          String
  lastName           String
  email              String          @unique
  phone              String?
  role               String
  department         String?
  specialty          String?
  licenseNumber      String?
  isActive           Boolean         @default(true)
  hireDate           DateTime        @default(now())
  lastLogin          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  auditLogs          AuditLog[]
  clinicalOrders     ClinicalOrder[]
  nurseTasksReceived NurseTask[]     @relation("NurseTasksByAssignee")
  nurseTasksAssigned NurseTask[]     @relation("NurseTasksByAssigner")
  prescriptions      Prescription[]
  soapAddenda        SoapAddendum[]
  soapNotesSigned    SoapNote[]      @relation("SoapNotesBySigner")
  soapNotesEdited    SoapNote[]      @relation("SoapNotesByEditor")
  soapNotes          SoapNote[]      @relation("SoapNotesByAuthor")
  vitalsRecords      VitalSigns[]

  @@map("employees")
}

/// Enhanced SOAP Note Model
model SoapNote {
  id                      String          @id @default(uuid())
  encounterId             String          @unique
  patientId               String
  chiefComplaint          String?
  hpiOnset                String?
  hpiLocation             String?
  hpiDuration             String?
  hpiCharacter            String?
  hpiAggravating          String?
  hpiRelieving            String?
  hpiTiming               String?
  hpiSeverity             Int?
  hpiNarrative            String?
  rosConstitutional       String?
  rosHeent                String?
  rosCardiovascular       String?
  rosRespiratory          String?
  rosGastrointestinal     String?
  rosGenitourinary        String?
  rosMusculoskeletal      String?
  rosNeurological         String?
  rosPsychiatric          String?
  rosEndocrine            String?
  rosHematologic          String?
  rosSkin                 String?
  pmhUpdate               String?
  pshUpdate               String?
  familyHistory           String?
  socialHistory           String?
  medicationsReview       String?
  allergiesConfirmed      Boolean         @default(false)
  obgynHistory            String?
  vitalsId                String?
  generalAppearance       String?
  peConstitutional        String?
  peHeent                 String?
  peCardiovascular        String?
  peRespiratory           String?
  peGastrointestinal      String?
  peGenitourinary         String?
  peMusculoskeletal       String?
  peNeurological          String?
  pePsychiatric           String?
  peSkin                  String?
  diagnosticResults       String?
  functionalAssessment    String?
  primaryDiagnosisCode    String?
  primaryDiagnosisDesc    String?
  differential1Code       String?
  differential1Desc       String?
  differential1Confidence String?
  differential2Code       String?
  differential2Desc       String?
  differential2Confidence String?
  differential3Code       String?
  differential3Desc       String?
  differential3Confidence String?
  differential4Code       String?
  differential4Desc       String?
  differential4Confidence String?
  differential5Code       String?
  differential5Desc       String?
  differential5Confidence String?
  clinicalReasoning       String?
  problemListUpdates      String?
  riskFlags               String?
  investigationsOrdered   String?
  medicationsPrescribed   String?
  referrals               String?
  patientEducation        String?
  followUpDate            DateTime?
  followUpMode            String?
  followUpClinician       String?
  nursingInstructions     String?
  disposition             String?
  dispositionDestination  String?
  dispositionReason       String?
  status                  String          @default("draft")
  signedAt                DateTime?
  signedBy                String?
  lockVersion             Int             @default(0)
  aiSuggestionsUsed       Boolean         @default(false)
  aiConfidence            Float?
  createdBy               String
  lastEditedBy            String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  orders                  ClinicalOrder[]
  nurseTasks              NurseTask[]
  prescriptions           Prescription[]
  addenda                 SoapAddendum[]
  signer                  Employee?       @relation("SoapNotesBySigner", fields: [signedBy], references: [employeeId])
  editor                  Employee?       @relation("SoapNotesByEditor", fields: [lastEditedBy], references: [employeeId])
  author                  Employee        @relation("SoapNotesByAuthor", fields: [createdBy], references: [employeeId])
  vitals                  VitalSigns?     @relation(fields: [vitalsId], references: [id])
  patient                 Patient         @relation(fields: [patientId], references: [id])

  @@map("soap_notes")
}

/// SOAP Note Addendum
model SoapAddendum {
  id           String   @id @default(uuid())
  soapNoteId   String
  addendumText String
  reason       String?
  authoredBy   String
  authoredAt   DateTime @default(now())
  author       Employee @relation(fields: [authoredBy], references: [employeeId])
  soapNote     SoapNote @relation(fields: [soapNoteId], references: [id])

  @@map("soap_addenda")
}

/// Clinical Orders (Labs, Imaging, Procedures)
model ClinicalOrder {
  id           String    @id @default(uuid())
  soapNoteId   String?
  patientId    String
  orderType    String
  orderName    String
  orderDetails String?
  urgency      String    @default("routine")
  status       String    @default("pending")
  orderedBy    String
  orderedAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?
  completedAt  DateTime?
  orderer      Employee  @relation(fields: [orderedBy], references: [employeeId])
  patient      Patient   @relation(fields: [patientId], references: [id])
  soapNote     SoapNote? @relation(fields: [soapNoteId], references: [id])

  @@map("clinical_orders")
}

/// Prescriptions
model Prescription {
  id                     String    @id @default(uuid())
  soapNoteId             String?
  patientId              String
  drugName               String
  dosage                 String
  frequency              String
  duration               String?
  quantity               Int?
  refills                Int       @default(0)
  instructions           String?
  allergyCheckPassed     Boolean   @default(false)
  interactionCheckPassed Boolean   @default(false)
  safetyWarnings         String?
  status                 String    @default("active")
  prescribedBy           String
  prescribedAt           DateTime  @default(now())
  dispensedAt            DateTime?
  dispensedBy            String?
  prescriber             Employee  @relation(fields: [prescribedBy], references: [employeeId])
  patient                Patient   @relation(fields: [patientId], references: [id])
  soapNote               SoapNote? @relation(fields: [soapNoteId], references: [id])

  @@map("prescriptions")
}

/// Nurse Tasks (from doctor's instructions)
model NurseTask {
  id              String    @id @default(uuid())
  soapNoteId      String
  patientId       String
  taskDescription String
  priority        String    @default("routine")
  status          String    @default("pending")
  assignedBy      String
  assignedTo      String?
  assignedAt      DateTime  @default(now())
  dueBy           DateTime?
  completedAt     DateTime?
  completedBy     String?
  notes           String?
  assignee        Employee? @relation("NurseTasksByAssignee", fields: [assignedTo], references: [employeeId])
  assigner        Employee  @relation("NurseTasksByAssigner", fields: [assignedBy], references: [employeeId])
  patient         Patient   @relation(fields: [patientId], references: [id])
  soapNote        SoapNote  @relation(fields: [soapNoteId], references: [id])

  @@map("nurse_tasks")
}

/// Immutable Audit Log
model AuditLog {
  id              String   @id @default(uuid())
  actorId         String
  actorName       String
  actorRole       String
  actorDepartment String?
  actionType      String
  resourceType    String
  resourceId      String?
  patientMrn      String?
  fieldChanged    String?
  oldValue        String?
  newValue        String?
  ipAddress       String?
  userAgent       String?
  timestamp       DateTime @default(now())
  actor           Employee @relation(fields: [actorId], references: [employeeId])

  @@index([actorId])
  @@index([patientMrn])
  @@index([actionType])
  @@index([timestamp])
  @@map("audit_logs")
}

/// ICD Codes Reference
model ICDCode {
  id          String  @id @default(uuid())
  code        String  @unique
  description String
  category    String?
  chapter     String?
  isICD11     Boolean @default(false)

  @@map("icd_codes")
}
