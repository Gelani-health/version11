# ============================================================
# Gelani Healthcare Assistant - Environment Configuration
# ============================================================
# 
# World-Class Clinical Decision Support System
# 
# Copy this file to .env and fill in your values
# Required values are marked with [REQUIRED]
# 
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# SQLite (Default - Works locally without setup)
DATABASE_URL="file:./data/healthcare.db"

# PostgreSQL (Production - Recommended for multi-user deployments)
# DATABASE_URL="postgresql://gelani:password@localhost:5432/gelani_healthcare"

# ============================================================
# SESSION & AUTHENTICATION
# ============================================================

# Session secret for NextAuth (REQUIRED - min 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET="gelani-healthcare-session-secret-key-minimum-32-characters-secure-production"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-another-secure-secret-key-here"

# Default Admin Credentials (for initial setup only)
# These will be created on first run
DEFAULT_ADMIN_EMAIL="admin@gelani.health"
DEFAULT_ADMIN_PASSWORD="change-this-password-immediately"

# ============================================================
# LLM PROVIDER CONFIGURATION
# ============================================================

# Z.AI (Built-in SDK - No additional configuration needed)
# The Z.AI SDK is built-in and works out of the box
# ZAI_API_KEY=""  # Optional: Your Z.AI API key if you have one
# ZAI_BASE_URL="https://api.z.ai/api/paas/v4"

# OpenAI (Optional - Requires API key)
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Anthropic Claude (Optional - Requires API key)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"

# Google Gemini (Optional - Requires API key)
# GOOGLE_API_KEY="..."
# GOOGLE_BASE_URL="https://generativelanguage.googleapis.com/v1"

# Ollama (Local - Free, requires Ollama installation)
# Download from: https://ollama.ai
# OLLAMA_BASE_URL="http://localhost:11434"

# ============================================================
# RAG SERVICE CONFIGURATION
# ============================================================

# Primary RAG uses embedded knowledge base (no configuration needed)
# Extended RAG services (Python-based) require:
RAG_SERVICE_PORT="3031"
LANGCHAIN_RAG_PORT="3032"

# Embedding settings
EMBEDDING_MODEL="feature-based-semantic"
EMBEDDING_DIMENSION="768"

# ============================================================
# ASR (SPEECH RECOGNITION) CONFIGURATION
# ============================================================

# ASR Service Port
ASR_SERVICE_PORT="3033"

# Whisper model (for local ASR)
# Options: tiny, base, small, medium, large
WHISPER_MODEL="medium"

# ============================================================
# AI MODEL SETTINGS
# ============================================================

# Default AI settings for clinical reasoning
AI_MODEL="GLM-4.7-Flash"
AI_TEMPERATURE="0.3"
AI_MAX_TOKENS="4096"
AI_CONTEXT_WINDOW="200000"

# ============================================================
# CLINICAL DECISION SUPPORT SETTINGS
# ============================================================

# Feature Flags
ENABLE_CLINICAL_DECISION_SUPPORT="true"
ENABLE_DRUG_INTERACTION_CHECK="true"
ENABLE_LAB_INTERPRETATION="true"
ENABLE_DIFFERENTIAL_DIAGNOSIS="true"
ENABLE_ICD_CODING="true"
ENABLE_IMAGE_ANALYSIS="true"
ENABLE_VOICE_TRANSCRIPTION="true"

# Safety Settings
REQUIRE_HUMAN_REVIEW="true"
LOG_ALL_INTERACTIONS="true"
SAFETY_ALERT_THRESHOLD="0.8"

# ============================================================
# HIPAA COMPLIANCE SETTINGS
# ============================================================

# Audit Log Retention (years) - HIPAA requires minimum 6 years
AUDIT_RETENTION_YEARS="7"

# Enable HIPAA-compliant audit logging
ENABLE_HIPAA_AUDIT="true"

# PHI Access Logging
LOG_PHI_ACCESS="true"

# Session Timeout (minutes)
SESSION_TIMEOUT_MINUTES="30"

# ============================================================
# ENCRYPTION CONFIGURATION
# ============================================================

# Encryption key for sensitive data (API keys, etc.)
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this key secure and backed up. Lost keys mean lost data.
ENCRYPTION_KEY="generate-a-secure-32-byte-base64-key-here"

# ============================================================
# INTEGRATION CONFIGURATION
# ============================================================

# Bahmni Integration (Optional)
# BAHMNI_URL="https://your-bahmni-instance.org"
# BAHMNI_USERNAME="your-username"
# BAHMNI_PASSWORD="your-password"
# BAHMNI_FHIR_ENDPOINT="/openmrs/ws/fhir2/R4"

# FHIR Server (Optional)
# FHIR_SERVER_URL="https://your-fhir-server.org/fhir"

# Odoo Integration (Optional - for billing/accounting)
# ODOO_URL="https://your-odoo-instance.com"
# ODOO_DATABASE="gelani"
# ODOO_API_KEY="your-api-key"

# ============================================================
# API SECURITY
# ============================================================

# API Key for service-to-service authentication
GELANI_API_KEY="your-secure-api-key-here"

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="60000"

# ============================================================
# BACKUP CONFIGURATION
# ============================================================

# Backup directory
BACKUP_DIR="./data/backups"

# Enable automatic backups
BACKUP_ON_WRITE="true"

# Backup retention (days)
BACKUP_RETENTION_DAYS="365"

# ============================================================
# LOGGING CONFIGURATION
# ============================================================

# Log level: debug, info, warn, error
LOG_LEVEL="info"

# Log directory
LOG_DIR="./logs"

# Enable file logging
ENABLE_FILE_LOGGING="true"

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Server port
PORT="3000"

# Node environment
NODE_ENV="development"

# Host
HOST="0.0.0.0"

# ============================================================
# MONITORING (Optional)
# ============================================================

# OpenTelemetry (Optional)
# OTEL_ENABLED="false"
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Sentry (Optional - Error tracking)
# NEXT_PUBLIC_SENTRY_DSN="https://..."
# SENTRY_DSN="https://..."
