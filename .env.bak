# Database Configuration
DATABASE_URL="file:./db/healthcare.db"

# Bahmni Configuration (Optional)
BAHMNI_URL="https://demo.bahmni.org"
BAHMNI_USERNAME="admin"
BAHMNI_PASSWORD="Admin123"
BAHMNI_FHIR_ENDPOINT="/openmrs/ws/fhir2/R4"

# AI Configuration
AI_MODEL="medgemma"
AI_TEMPERATURE="0.7"
AI_MAX_TOKENS="2048"

# Feature Flags
ENABLE_CLINICAL_DECISION_SUPPORT="true"
ENABLE_DRUG_INTERACTION_CHECK="true"
ENABLE_IMAGE_ANALYSIS="true"
ENABLE_VOICE_TRANSCRIPTION="true"

# Safety Settings
REQUIRE_HUMAN_REVIEW="true"
LOG_ALL_INTERACTIONS="true"
SAFETY_ALERT_THRESHOLD="0.8"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gelani-healthcare-secret-key-change-in-production"

# Mini-services URLs
MEDICAL_RAG_SERVICE_URL="http://localhost:3031"
LANGCHAIN_RAG_SERVICE_URL="http://localhost:3032"
MEDASR_SERVICE_URL="http://localhost:3033"

# API Authentication (Master Key - change in production)
GELANI_API_KEY="gelani_live_Kj8mN2pQ5rT9vW3xY7zA1bC4dE6fG0hI"

# Z.AI API Configuration
ZAI_API_KEY="${ZAI_API_KEY}"
ZAI_BASE_URL="https://api.z.ai/api/paas/v4"
GLM_MODEL="glm-4.7-flash"

# Pinecone Configuration
PINECONE_API_KEY="${PINECONE_API_KEY}"
PINECONE_INDEX_NAME="medical-diagnostic-rag"
PINECONE_NAMESPACE="pubmed"

# NCBI Configuration
NCBI_API_KEY="${NCBI_API_KEY}"
NCBI_EMAIL="info@gelani-health.ai"
