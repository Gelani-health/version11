{
  "name": "gelani-healthcare-assistant",
  "version": "2.0.0",
  "description": "AI-Powered Clinical Decision Support System for Healthcare Professionals",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "services:start": "bun run start-services.ts",
    "services:start:bg": "bun run start-services.ts &",
    "services:start:full": "bash start-all.sh --detach",
    "services:stop": "bash stop-all.sh",
    "services:status": "curl -s http://localhost:3031/health && curl -s http://localhost:3032/health && curl -s http://localhost:3033/health",
    "services:check": "curl -s http://localhost:3031/health | echo && curl -s http://localhost:3032/health | echo && curl -s http://localhost:3033/health | echo",
    "kill:all": "npx kill-port 3000 3031 3032 3033",
    "kill:win": "powershell -Command \"Get-Process -Name node,bun -ErrorAction SilentlyContinue | Stop-Process -Force\"",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "bun run prisma/seed-patients.ts",
    "db:seed:services": "bun run prisma/seed-services.ts",
    "db:seed:all": "bun run db:seed && bun run db:seed:services",
    "db:backup": "bunx tsx scripts/backup-service.ts backup",
    "db:backups": "bunx tsx scripts/backup-service.ts list",
    "db:restore": "bunx tsx scripts/backup-service.ts restore",
    "db:verify": "bunx tsx scripts/backup-service.ts verify",
    "db:health": "bunx tsx scripts/backup-service.ts health",
    "db:cleanup": "bunx tsx scripts/backup-service.ts cleanup",
    "db:safe-push": "bunx tsx scripts/db-safe-push.ts",
    "db:wal": "sqlite3 data/healthcare.db 'PRAGMA journal_mode=WAL;'",
    "db:checkpoint": "sqlite3 data/healthcare.db 'PRAGMA wal_checkpoint(TRUNCATE);'",
    "db:integrity": "sqlite3 data/healthcare.db 'PRAGMA integrity_check;'",
    "db:pragmas": "echo 'SQLite PRAGMA settings are applied automatically on startup'",
    "setup": "bun install && bun run db:generate && bun run db:push && bun run db:seed:all",
    "setup:full": "bun install && bun run db:generate && bun run db:push && bun run db:seed:all && bun run services:start",
    "setup:services": "cd mini-services && python3 -m venv venv && source venv/bin/activate && pip install -r medical-rag-service/requirements.txt",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:preview": "docker compose up -d && docker compose logs -f gelani-app",
    "preview": "npm run services:start && npm run dev",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:start:prod": "npx pm2 start ecosystem.config.prod.js --env production",
    "pm2:start:main": "npx pm2 start ecosystem.config.js --only gelani-main",
    "pm2:stop": "npx pm2 stop all",
    "pm2:stop:main": "npx pm2 stop gelani-main",
    "pm2:restart": "npx pm2 restart all",
    "pm2:reload": "npx pm2 reload all",
    "pm2:logs": "npx pm2 logs",
    "pm2:logs:main": "npx pm2 logs gelani-main",
    "pm2:delete": "npx pm2 delete all",
    "pm2:status": "npx pm2 list",
    "pm2:save": "npx pm2 save",
    "pm2:startup": "npx pm2 startup",
    "pm2:monit": "npx pm2 monit",
    "pm2:flush": "npx pm2 flush",
    "pm2:reset": "npx pm2 reset",
    "start:all": "bun run services:start && bun run dev",
    "start:pm2": "bun run pm2:start && bun run pm2:save",
    "start:pm2:prod": "bun run pm2:start:prod && bun run pm2:save",
    "health": "curl -s http://localhost:3000/api/health && echo '' && curl -s http://localhost:3031/health && echo '' && curl -s http://localhost:3032/health && echo '' && curl -s http://localhost:3033/health"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.44.0",
    "@hookform/resolvers": "^5.1.1",
    "@mdxeditor/editor": "^3.39.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.45.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.49.0",
    "@opentelemetry/resources": "^1.22.0",
    "@opentelemetry/sdk-node": "^0.49.0",
    "@opentelemetry/semantic-conventions": "^1.22.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@reactuses/core": "^6.0.5",
    "@tanstack/react-query": "^5.82.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.11",
    "next-intl": "^4.3.4",
    "next-themes": "^0.4.6",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "z-ai-web-dev-sdk": "^0.0.16",
    "zod": "^3.23.8",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "pm2": "^6.0.14",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
